{
  "name": "@dawnphase/worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --env development",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "db:migrate:local": "wrangler d1 migrations apply dawnphase-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply dawnphase-db"
  },
  "dependencies": {
    "hono": "^4.7.7",
    "@hono/zod-validator": "^0.4.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250422.0",
    "typescript": "^5",
    "wrangler": "^4.9.1"
  }
}
